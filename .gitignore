# ==============================================
# FRONTEND - Angular
# ==============================================

# Build output
front-survey-platform/dist/
front-survey-platform/out-tsc/
front-survey-platform/tmp/
front-survey-platform/coverage/
front-survey-platform/e2e/test-output/

# Angular cache
front-survey-platform/.angular/
front-survey-platform/.angular/

# Dependencies
front-survey-platform/node_modules/

# Lock files (elige uno y bórralo si usas el otro)
front-survey-platform/package-lock.json
front-survey-platform/yarn.lock

# Variables de entorno
front-survey-platform/.env
front-survey-platform/.env.*

# Angular CLI legacy
front-survey-platform/.angular-cli.json
front-survey-platform/.ng/

# TypeScript cache
front-survey-platform/*.tsbuildinfo
*.tsbuildinfo

# Logs npm/yarn
front-survey-platform/npm-debug.log*
front-survey-platform/yarn-debug.log*
front-survey-platform/yarn-error.log*


# ==============================================
# BACKEND - Spring Boot / Maven / Gradle
# ==============================================

# Maven
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar

# Gradle
backend/.gradle/
backend/build/
backend/out/
!backend/gradle/wrapper/gradle-wrapper.jar

# Variables de entorno y configuración local
backend/.env
backend/.env.*
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-secret.properties

# Logs
backend/*.log
backend/logs/

# Spring Boot ejecutable empaquetado (opcional, comenta si quieres versionarlo)
backend/*.jar
backend/*.war


